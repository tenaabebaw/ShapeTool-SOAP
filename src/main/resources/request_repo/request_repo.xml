<?xml version="1.0" encoding="UTF-8"?>

<!-- ================= SOAP REQUEST & RESPONSE SAMPLES ================= -->
<!-- Namespace: http://ShapeTool.com/ShapeArea -->

<!-- ========================================================= -->
<!-- ======================= CIRCLE ========================== -->
<!-- ========================================================= -->

<!-- VALID REQUEST -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:shap="http://ShapeTool.com/ShapeArea">
    <soapenv:Header/>
    <soapenv:Body>
        <shap:CircleAreaRequest>
            <shap:radius>5</shap:radius>
        </shap:CircleAreaRequest>
    </soapenv:Body>
</soapenv:Envelope>

        <!-- VALID RESPONSE -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:shap="http://ShapeTool.com/ShapeArea">
<soapenv:Header/>
<soapenv:Body>
    <shap:CircleAreaResponse>
        <shap:area>78.53981633974483</shap:area>
    </shap:CircleAreaResponse>
</soapenv:Body>
</soapenv:Envelope>

        <!-- INVALID REQUEST -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:shap="http://ShapeTool.com/ShapeArea">
<soapenv:Header/>
<soapenv:Body>
    <shap:CircleAreaRequest>
        <shap:radius>-5</shap:radius>
    </shap:CircleAreaRequest>
</soapenv:Body>
</soapenv:Envelope>

        <!-- SOAP FAULT -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/">
<soapenv:Header/>
<soapenv:Body>
    <soapenv:Fault>
        <faultcode>soapenv:Client</faultcode>
        <faultstring>Radius cannot be negative</faultstring>
    </soapenv:Fault>
</soapenv:Body>
</soapenv:Envelope>

